#!/bin/sh
# pre-push gate — runs typecheck + lint + test + test:contract before
# allowing any push to leave the local machine.
#
# Why this exists:
#   `bun work submit` has the SAME gate sequence built in, but agents
#   regularly fall back to `git push -u origin <branch> && gh pr create`
#   (because `bun work submit` has an open worktree-gitdir bug — task #20).
#   Without a pre-push hook, broken commits skip the gates entirely and
#   only fail in CI 5–10 minutes later, polluting PR state and burning
#   reviewer time.
#
# This hook closes the gap: every `git push` runs the same four gates
# `bun work submit` runs, and blocks the push on any failure. Identical
# gate set, identical hint text — agents can fix locally and re-push,
# no CI round-trip.
#
# Bypass with `git push --no-verify` for documented emergencies (release
# automation, hot-fix where CI is the gate, etc.). NEVER bypass to ship
# broken code; CI will reject it anyway and you've just delayed the
# inevitable.
#
# Activated via `core.hooksPath = .githooks` (set by the `prepare`
# script in package.json on every `bun install`).
#
# Skip rules — keep this hook fast and predictable:
#   - Skip on push of a branch with zero local commits ahead of remote
#     (a no-op push). The gates have nothing to validate.
#   - Skip on push of an empty ref-list (e.g., `git push --tags`-only).
#
# Performance:
#   - Cold cache: ~30s on a 10-package workspace. Tolerable.
#   - Warm: ~10s.
#   - If you push frequently and gates feel slow, fix the gates' speed,
#     don't disable the hook.

set -e

# Read stdin: each line is `<local_ref> <local_sha> <remote_ref> <remote_sha>`.
# Skip if all entries are deletions (local_sha is all zeros) or no-ops.
has_real_push=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip empty input.
  if [ -z "$local_sha" ]; then continue; fi
  # Deletion: local_sha is `0000...`. Don't run gates on a deletion.
  zero="0000000000000000000000000000000000000000"
  if [ "$local_sha" = "$zero" ]; then continue; fi
  has_real_push=1
done

if [ "$has_real_push" -eq 0 ]; then
  exit 0
fi

# Color helpers (skipped if not a TTY).
if [ -t 2 ]; then
  bold=$(printf '\033[1m')
  red=$(printf '\033[31m')
  green=$(printf '\033[32m')
  cyan=$(printf '\033[36m')
  reset=$(printf '\033[0m')
else
  bold=''; red=''; green=''; cyan=''; reset=''
fi

echo "${bold}[pre-push] running gates before allowing push to leave the machine${reset}" >&2
echo "${bold}[pre-push] bypass with \`git push --no-verify\` for documented emergencies${reset}" >&2

# Skip if bun isn't installed (e.g., running in a container without the
# repo's tooling). Loud warning so the gap is visible.
if ! command -v bun >/dev/null 2>&1; then
  echo "${red}[pre-push] WARNING: bun not on PATH; skipping gates. Install Bun >=1.1 to re-enable.${reset}" >&2
  exit 0
fi

# Skip if node_modules is missing (no bun install has run yet). Same
# rationale — visible warning, no blanket fail.
if [ ! -d node_modules ]; then
  echo "${red}[pre-push] WARNING: node_modules missing; run \`bun install\` first. Skipping gates.${reset}" >&2
  exit 0
fi

run_gate() {
  name="$1"
  cmd="$2"
  hint="$3"
  echo "${cyan}[pre-push] → ${name}${reset}" >&2
  if ! eval "$cmd" >&2; then
    echo "" >&2
    echo "${red}${bold}[pre-push] gate FAILED: ${name}${reset}" >&2
    echo "${red}[pre-push] ${hint}${reset}" >&2
    echo "" >&2
    echo "${bold}push BLOCKED. Fix the failure and re-run \`git push\`.${reset}" >&2
    echo "${bold}emergency bypass: \`git push --no-verify\` (CI will still gate)${reset}" >&2
    exit 1
  fi
}

run_gate "typecheck" \
  "bun run typecheck" \
  "fix the TS errors above; zero \`any\`, zero \`// @ts-ignore\` (AGENTS.md §6)"

run_gate "lint" \
  "bun run lint" \
  "run \`bun run lint:fix\` to auto-fix what biome can; resolve the rest"

run_gate "test (unit)" \
  "bun run test" \
  "fix the failing test(s) — do not skip flaky tests (AGENTS.md §12)"

run_gate "test:contract" \
  "bun run test:contract" \
  "see tests/contract/ for the cross-package contracts"

echo "${green}${bold}[pre-push] all gates green — push proceeding${reset}" >&2
exit 0
